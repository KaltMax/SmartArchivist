{
  "Urls": "http://*:8084",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "ColorBehavior": "Enabled",
        "SingleLine": false,
        "IncludeScopes": true,
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss "
      }
    }
  },
  "ConnectionStrings": {
    "SmartArchivistDb": "Host=postgres;Port=5432;Database=smartarchivist;Username=postgres;Password=changeme"
  },
  "LicenceKeys": {
    "AutoMapperLicenceKey": "your-licence-key-here"
  },
  "RabbitMQ": {
    "HostName": "rabbitmq",
    "Port": 5672,
    "UserName": "smartarchivist",
    "Password": "changeme",
    "VirtualHost": "/"
  },
  "ElasticSearch": {
    "Url": "http://elasticsearch:9200",
    "IndexName": "smartarchivist-documents",
    "MaxSearchResults":  10
  }
}
